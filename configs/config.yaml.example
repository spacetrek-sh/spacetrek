environment: development

server:
  http_addr: ":8080"
  read_timeout: 15s
  write_timeout: 30s
  idle_timeout: 60s

database:
  url: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@psql:5432/${POSTGRES_DB}?sslmode=disable
  max_connections: 50

log:
  level: debug

vm:
  provider: firecracker
  pool_size: 10
  max_vms: 100
  cpu_count: 2
  memory_mb: 512
  disk_mb: 2048
  network_enabled: true
  idle_timeout: 5m
  max_lifetime: 1h
  auto_snapshot: true
  resume_grace: 2m
  disk_mode: self_contained   # "full" | "self_contained" | "incremental"
  max_chain_length: 5
  max_chain_age_minutes: 120
  firecracker:
    binary_path: firecracker
    kernel_path: /usr/share/firecracker/vmlinux
    base_dir: /var/lib/firecracker/vms
    kernel_args: console=ttyS0 reboot=k panic=1 pci=off rw init=/usr/local/bin/spacetrk-vsock-agent
    mac_address: 02:FC:00:00:00:01
    socket_timeout: 30
    shutdown_timeout: 10
    smt: false
    enable_mmds: true
    exec_enabled: true
    guest_agent_port: 10789
    vsock_socket_name: agent.vsock
    cid_min: 1024
    cid_max: 65535
    default_exec_timeout: 60s
    max_stdout_bytes: 5242880
    max_stderr_bytes: 5242880
    network:
      bridge_name: br-stk
      subnet: 10.200.0.0/16
      gateway_ip: 10.200.0.1
      dns_ip: 10.200.0.1
      ip_start: 10.200.0.2
      ip_end: 10.200.255.254
      enable_nat: true

llm:
  default_provider: gemini
  timeout: 60s
  max_retries: 3
  gemini:
    api_key: ${GEMINI_API_KEY}
    model: gemini-3-flash-preview
    max_output_tokens: 4096

storage:
  endpoint: "http://rustfs:9000"
  region: "us-east-1"
  access_key: ${RUSTFS_ACCESS_KEY}
  secret_key: ${RUSTFS_SECRET_KEY}
  bucket: "spacetrk-snapshots"
  use_path_style: true

security:
  jwt_secret: ${JWT_SECRET}
  access_token_expiry: 1h
  refresh_token_expiry: 720h
  max_task_duration: 5m

observability:
  metrics_enabled: true
  tracing_enabled: false
  tracing_endpoint: "localhost:4318"
