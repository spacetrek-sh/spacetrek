# Spacetrek environment variables.
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored — never commit real secrets.

# PostgreSQL (used by the psql container, migrate service, and configs/config.yaml)
POSTGRES_USER=spacetrek
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=spacetrek

# RustFS (S3-compatible object storage)
RUSTFS_ACCESS_KEY=spacetrek
RUSTFS_SECRET_KEY=replace-with-strong-secret

# Application secrets (expanded into configs/config.yaml at startup via ${VAR})
JWT_SECRET=replace-with-random-32-bytes
GEMINI_API_KEY=replace-with-your-gemini-key
